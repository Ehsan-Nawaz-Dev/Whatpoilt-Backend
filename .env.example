PORT=8080
ENVIRONMENT=development   # set to "production" on Contabo

# Shopify webhook HMAC secret (from Partners dashboard → App setup → Webhooks)
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# Shared API key between this backend and the Remix frontend.
# Generate a strong random string: openssl rand -hex 32
BACKEND_API_KEY=change_me_to_a_long_random_secret

# CORS — origin of the Remix frontend
FRONTEND_URL=https://your-app.vercel.app

# SQLite app database path
DB_PATH=./data/whatsapp.db
# Per-shop WhatsApp session DBs are stored in ./data/sessions/<shop>.db automatically
